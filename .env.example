# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

ENABLE_HSTS=false
NEXT_OUTPUT_MODE=serverless
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local SQLite (default — no credentials needed):
DATABASE_URL=file:./sqlite.db

# Local debug against a forked Turso DB (use: npm run db:debug:remote:start / npm run db:debug:remote:stop).
# DATABASE_URL=libsql://your-db.aws-eu-west-1.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Turso API token — used by CI to derive DATABASE_URL + auth token at deploy time,
# and to fork the prod DB for PR previews and local debug sessions.
# Generate at: app.turso.tech → Settings → API Tokens
# TURSO_API_TOKEN=your-turso-api-token

# Vercel deploy token (CI github actions - deploy to vercel).
# Generate at: vercel.com → Account Settings → Tokens
# VERCEL_TOKEN=your-vercel-token

# AES-256 passphrase for encrypting pre-migration DB snapshots uploaded to GitHub Actions.
# Auto-generated by infra:setup — do not set manually.
# DB_SNAPSHOT_PASSPHRASE=
